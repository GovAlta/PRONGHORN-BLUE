# Terraform variables file with sensitive values
# Use terraform.tfvars.example as a template instead
*.tfvars
!*.tfvars.example
!infra/params/dev.tfvars
!infra/params/uat.tfvars
!infra/params/prod.tfvars

# Terraform backend config (non-secret tfstate identifiers). Customer-specific
# files (e.g. goa) are gitignored like their tfvars; dev/uat/prod are committed.
infra/params/*.backend.hcl
!infra/params/dev.backend.hcl
!infra/params/uat.backend.hcl
!infra/params/prod.backend.hcl

