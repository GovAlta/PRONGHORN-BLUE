{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Start Frontend Dev Server",
			"type": "npm",
			"script": "dev",
			"path": "app/frontend",
			"isBackground": true,
			"problemMatcher": {
				"owner": "vite",
				"fileLocation": "absolute",
				"pattern": {
					"regexp": "^\\[vite\\]\\s+(.+):(\\d+):(\\d+):\\s+(.+)$",
					"file": 1,
					"line": 2,
					"column": 3,
					"message": 4
				},
				"background": {
					"activeOnStart": true,
					"beginsPattern": "vite_react_shadcn_ts",
					"endsPattern": "Local:\\s+http"
				}
			}
		}
	]
}