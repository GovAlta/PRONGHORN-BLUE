{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug API",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "npx",
            "runtimeArgs": [
                "ts-node",
                "src/index.ts"
            ],
            "cwd": "${workspaceFolder}/app/backend",
            "envFile": "${workspaceFolder}/.env",
            "sourceMaps": true,
            "console": "integratedTerminal",
            "internalConsoleOptions": "neverOpen",
            "skipFiles": [
                "<node_internals>/**",
                "node_modules/**"
            ]
        },
        {
            "name": "Debug Frontend (Chrome)",
            "type": "chrome",
            "request": "launch",
            "url": "http://localhost:8080",
            "webRoot": "${workspaceFolder}/app/frontend/src",
            "sourceMapPathOverrides": {
                "webpack:///src/*": "${webRoot}/*",
                "webpack:///./src/*": "${webRoot}/*"
            },
            "preLaunchTask": "Start Frontend Dev Server"
        },
        {
            "name": "Debug Frontend (Edge)",
            "type": "msedge",
            "request": "launch",
            "url": "http://localhost:8080",
            "webRoot": "${workspaceFolder}/app/frontend/src",
            "sourceMapPathOverrides": {
                "webpack:///src/*": "${webRoot}/*",
                "webpack:///./src/*": "${webRoot}/*"
            },
            "preLaunchTask": "Start Frontend Dev Server"
        }
    ],
    "compounds": [
        {
            "name": "Debug Full Stack (API + Frontend)",
            "configurations": [
                "Debug API",
                "Debug Frontend (Chrome)"
            ],
            "stopAll": true
        }
    ]
}