# =============================================================================
# Terraform Gitignore
# =============================================================================

# Local .terraform directories
.terraform/
.terraform.lock.hcl

# Terraform state files (CONTAIN SENSITIVE DATA)
*.tfstate
*.tfstate.*
terraform.tfstate
terraform.tfstate.backup

# Crash log files
crash.log
crash.*.log

# Plan files
*.tfplan
tfplan

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore CLI configuration files
.terraformrc
terraform.rc

# Ignore .tfvars files with secrets (use .tfvars.example as template)
params/*.tfvars
!params/*.tfvars.example
!params/dev.tfvars
!params/uat.tfvars
!params/prod.tfvars
*.auto.tfvars
secrets.tfvars

# Backend config (non-secret tfstate identifiers). Customer-specific files
# (e.g. goa) are gitignored like their tfvars; dev/uat/prod are committed.
params/*.backend.hcl
!params/dev.backend.hcl
!params/uat.backend.hcl
!params/prod.backend.hcl
