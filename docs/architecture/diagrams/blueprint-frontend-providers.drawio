<mxfile host="draw.io">
  <diagram name="Frontend Provider Hierarchy" id="frontend-providers">
    <mxGraphModel dx="1100" dy="700" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="700" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="title" value="&lt;b&gt;Frontend Provider Hierarchy &amp; Data Flow&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;fontSize=18;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="250" y="20" width="600" height="35" as="geometry" />
        </mxCell>

        <!-- Outermost: ThemeProvider -->
        <mxCell id="theme" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3E5F5;strokeColor=#9C27B0;strokeWidth=2;arcSize=6;dashed=0;" vertex="1" parent="1">
          <mxGeometry x="40" y="70" width="1020" height="580" as="geometry" />
        </mxCell>
        <mxCell id="theme-label" value="&lt;b&gt;ThemeProvider&lt;/b&gt; (next-themes, class-based dark mode)" style="text;html=1;align=left;verticalAlign=top;fontSize=12;fontColor=#7B1FA2;" vertex="1" parent="1">
          <mxGeometry x="55" y="78" width="400" height="20" as="geometry" />
        </mxCell>

        <!-- QueryClientProvider -->
        <mxCell id="query" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#4CAF50;strokeWidth=2;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="70" y="110" width="960" height="520" as="geometry" />
        </mxCell>
        <mxCell id="query-label" value="&lt;b&gt;QueryClientProvider&lt;/b&gt; (TanStack React Query — staleTime: 5m)" style="text;html=1;align=left;verticalAlign=top;fontSize=12;fontColor=#2E7D32;" vertex="1" parent="1">
          <mxGeometry x="85" y="118" width="450" height="20" as="geometry" />
        </mxCell>

        <!-- MsalProvider -->
        <mxCell id="msalp" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1976D2;strokeWidth=2;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="100" y="150" width="900" height="460" as="geometry" />
        </mxCell>
        <mxCell id="msal-label" value="&lt;b&gt;MsalProvider&lt;/b&gt; (Azure AD MSAL instance — PKCE / OIDC)" style="text;html=1;align=left;verticalAlign=top;fontSize=12;fontColor=#1565C0;" vertex="1" parent="1">
          <mxGeometry x="115" y="158" width="450" height="20" as="geometry" />
        </mxCell>

        <!-- AuthProvider -->
        <mxCell id="authp" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#FB8C00;strokeWidth=2;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="130" y="190" width="840" height="400" as="geometry" />
        </mxCell>
        <mxCell id="auth-label" value="&lt;b&gt;AuthProvider&lt;/b&gt; (user, session, loading, refreshAuth, getAccessToken)" style="text;html=1;align=left;verticalAlign=top;fontSize=12;fontColor=#E65100;" vertex="1" parent="1">
          <mxGeometry x="145" y="198" width="500" height="20" as="geometry" />
        </mxCell>

        <!-- AdminProvider -->
        <mxCell id="adminp" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFEBEE;strokeColor=#E53935;strokeWidth=2;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="160" y="230" width="780" height="340" as="geometry" />
        </mxCell>
        <mxCell id="admin-label" value="&lt;b&gt;AdminProvider&lt;/b&gt; (role, isAdmin, isSuperAdmin)" style="text;html=1;align=left;verticalAlign=top;fontSize=12;fontColor=#C62828;" vertex="1" parent="1">
          <mxGeometry x="175" y="238" width="400" height="20" as="geometry" />
        </mxCell>

        <!-- BrowserRouter -->
        <mxCell id="router" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#9E9E9E;strokeWidth=2;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="190" y="270" width="720" height="280" as="geometry" />
        </mxCell>
        <mxCell id="router-label" value="&lt;b&gt;BrowserRouter&lt;/b&gt; (React Router v6)" style="text;html=1;align=left;verticalAlign=top;fontSize=12;fontColor=#616161;" vertex="1" parent="1">
          <mxGeometry x="205" y="278" width="300" height="20" as="geometry" />
        </mxCell>

        <!-- App Component -->
        <mxCell id="app" value="&lt;b&gt;&amp;lt;App /&amp;gt;&lt;/b&gt;&lt;br&gt;ScrollToTop + PWAUpdatePrompt + Suspense" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=2;arcSize=10;shadow=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="220" y="310" width="300" height="50" as="geometry" />
        </mxCell>

        <!-- Toaster -->
        <mxCell id="toaster" value="&lt;b&gt;&amp;lt;Toaster /&amp;gt;&lt;/b&gt;&lt;br&gt;Sonner notifications" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=2;arcSize=10;shadow=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="560" y="310" width="200" height="50" as="geometry" />
        </mxCell>

        <!-- Route Groups -->
        <mxCell id="public-routes" value="&lt;b&gt;Public Routes&lt;/b&gt;&lt;br&gt;/ • /auth • /terms&lt;br&gt;/privacy • /license" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=1;arcSize=8;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="220" y="390" width="140" height="70" as="geometry" />
        </mxCell>
        <mxCell id="dash-routes" value="&lt;b&gt;Dashboard Routes&lt;/b&gt;&lt;br&gt;/dashboard • /gallery&lt;br&gt;/standards • /settings" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF9C4;strokeColor=#F9A825;strokeWidth=1;arcSize=8;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="380" y="390" width="150" height="70" as="geometry" />
        </mxCell>
        <mxCell id="proj-routes" value="&lt;b&gt;Project Routes&lt;/b&gt;&lt;br&gt;/project/:id/chat&lt;br&gt;/project/:id/canvas&lt;br&gt;+11 more sub-routes" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF9C4;strokeColor=#F9A825;strokeWidth=1;arcSize=8;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="550" y="390" width="160" height="70" as="geometry" />
        </mxCell>
        <mxCell id="token-routes" value="&lt;b&gt;Token Routes&lt;/b&gt;&lt;br&gt;/project/:id/:page&lt;br&gt;/t/:token&lt;br&gt;(anonymous access)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=1;arcSize=8;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="730" y="390" width="150" height="70" as="geometry" />
        </mxCell>

        <!-- API Client box -->
        <mxCell id="apiclient" value="&lt;b&gt;apiClient&lt;/b&gt; (lib/apiClient.ts)&lt;br&gt;MSAL token acquisition → Bearer header → APIM subscription key" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E0F7FA;strokeColor=#00838F;strokeWidth=2;arcSize=8;shadow=1;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="220" y="490" width="660" height="40" as="geometry" />
        </mxCell>

        <!-- Arrow from App to routes -->
        <mxCell id="app-routes" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#9E9E9E;strokeWidth=1;dashed=1;" edge="1" source="app" target="public-routes" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
