        </mxCell>

        <mxCell id="ga-env" value="&lt;font style=&quot;font-size:9px&quot;&gt;&lt;b&gt;Env:&lt;/b&gt; pbmm-internal &amp;nbsp;|&amp;nbsp; &lt;b&gt;Inputs:&lt;/b&gt; app_id, app_name, resource_group, repo_url, branch, action (create/deploy/destroy)&lt;/font&gt;" style="text;html=1;align=left;fontSize=9;fontColor=#666;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="50" y="930" width="700" height="20" as="geometry" />
        </mxCell>

        <!-- ================ FLOW ARROW between CI and CD sections ================ -->
        <mxCell id="e-ci-cd" value="&lt;b&gt;merge to main&lt;/b&gt;" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#333;strokeWidth=2;dashed=1;fontSize=10;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="ci-pass" target="cd-push" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1130" y="440" />
              <mxPoint x="110" y="440" />
