        <!-- DB2: Generated Apps Database -->
        <mxCell id="db2-group" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8EAF6;strokeColor=#5C6BC0;strokeWidth=2;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="600" y="310" width="450" height="290" as="geometry" />
        </mxCell>
        <mxCell id="db2-cylinder" value="&lt;b&gt;db-generated-apps&lt;/b&gt; — PostgreSQL 16&lt;br&gt;Port 5433" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#C5CAE9;strokeColor=#3F51B5;strokeWidth=2;size=15;fontSize=13;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="700" y="320" width="250" height="60" as="geometry" />
        </mxCell>
        <mxCell id="db2-desc" value="Per-project databases (proj_*)&lt;br&gt;Dynamic schema per generated application" style="text;html=1;align=center;fontSize=12;fontColor=#3F51B5;" vertex="1" parent="1">
