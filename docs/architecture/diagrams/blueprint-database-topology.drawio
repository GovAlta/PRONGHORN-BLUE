        <mxCell id="proj-c" value="proj_..." style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#BBDEFB;strokeColor=#42A5F5;size=10;fontSize=10;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="910" y="460" width="100" height="50" as="geometry" />
        </mxCell>

        <!-- Arrows from pool factory to databases -->
        <mxCell id="pool-db1" value="target: app" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#F9A825;strokeWidth=2;fontSize=10;fontColor=#666;" edge="1" source="pool-factory" target="db1-cylinder" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="pool-db2" value="target: genapps" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#3F51B5;strokeWidth=2;fontSize=10;fontColor=#666;" edge="1" source="pool-factory" target="db2-cylinder" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Enums box -->
        <mxCell id="enums" value="&lt;b&gt;Key Enums&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px;&quot;&gt;deployment_status: pending → building → deploying → active / failed → destroying → destroyed&lt;br&gt;database_status: creating → active / failed → deleting → deleted&lt;br&gt;project_status: active | archived | deleted&lt;br&gt;app_role: admin | editor | viewer&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#E65100;strokeWidth=1;arcSize=6;fontSize=10;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="600" y="650" width="450" height="90" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
