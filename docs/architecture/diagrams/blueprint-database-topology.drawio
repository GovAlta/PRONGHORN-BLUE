          <mxGeometry x="70" y="670" width="250" height="20" as="geometry" />
        </mxCell>
        <mxCell id="repo-t" value="repo_*" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E1BEE7;strokeColor=#8E24AA;fontSize=10;" vertex="1" parent="1">
