        </mxCell>
        <mxCell id="bb-t" value="build_books" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E1BEE7;strokeColor=#8E24AA;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="150" y="695" width="85" height="30" as="geometry" />
        </mxCell>
        <mxCell id="stds-t" value="standards" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E1BEE7;strokeColor=#8E24AA;fontSize=10;" vertex="1" parent="1">
