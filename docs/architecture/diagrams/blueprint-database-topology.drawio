<mxfile host="draw.io">
  <diagram name="Database Topology" id="db-topology">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="800" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="title" value="&lt;b&gt;Pronghorn — Data Architecture&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;fontSize=18;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="350" y="20" width="500" height="35" as="geometry" />
        </mxCell>

        <!-- Express API -->
        <mxCell id="api" value="&lt;b&gt;Express.js API&lt;/b&gt;&lt;br&gt;utils/database.ts&lt;br&gt;pg.Pool (max 20)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=2;arcSize=12;shadow=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="440" y="80" width="240" height="70" as="geometry" />
        </mxCell>

        <!-- Pool Factory -->
        <mxCell id="pool-factory" value="&lt;b&gt;getPoolForTarget()&lt;/b&gt;&lt;br&gt;Multi-database pool factory" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E0F7FA;strokeColor=#00838F;strokeWidth=2;arcSize=10;shadow=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="455" y="200" width="210" height="50" as="geometry" />
        </mxCell>

        <!-- Arrow API to pool factory -->
        <mxCell id="api-pool" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#00838F;strokeWidth=2;" edge="1" source="api" target="pool-factory" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- DB1: Application Database -->
        <mxCell id="db1-group" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF8E1;strokeColor=#F9A825;strokeWidth=2;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="50" y="310" width="450" height="440" as="geometry" />
        </mxCell>
        <mxCell id="db1-cylinder" value="&lt;b&gt;db&lt;/b&gt; — PostgreSQL 16&lt;br&gt;Port 5432" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;strokeWidth=2;size=15;fontSize=13;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="170" y="320" width="200" height="60" as="geometry" />
        </mxCell>

        <!-- Auth Schema -->
        <mxCell id="auth-schema" value="&lt;b&gt;auth schema&lt;/b&gt;" style="text;html=1;align=left;fontSize=12;fontColor=#E65100;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="70" y="400" width="120" height="20" as="geometry" />
        </mxCell>
        <mxCell id="auth-users" value="auth.users&lt;br&gt;&lt;font style=&quot;font-size:9px;&quot;&gt;id • email • encrypted_password&lt;br&gt;role • metadata&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFECB3;strokeColor=#FFB300;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="70" y="425" width="190" height="50" as="geometry" />
        </mxCell>
        <mxCell id="auth-tokens" value="auth.one_time_tokens&lt;br&gt;&lt;font style=&quot;font-size:9px;&quot;&gt;FK → auth.users&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFECB3;strokeColor=#FFB300;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="280" y="425" width="190" height="50" as="geometry" />
        </mxCell>

        <!-- Public Schema - Core -->
        <mxCell id="pub-core" value="&lt;b&gt;public schema — core&lt;/b&gt;" style="text;html=1;align=left;fontSize=12;fontColor=#1565C0;fontStyle=1;" vertex="1" parent="1">
