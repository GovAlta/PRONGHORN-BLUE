# =============================================================================
# Pronghorn — Shared Local Development Environment Variables
# =============================================================================
# Copy this file to .env and customise as needed.
# Docker Compose reads this file automatically from the repo root.
# The backend API also loads this file as a fallback for shared variables.
#
# All values below are local-dev defaults. Override in .env as needed.
# NEVER commit .env files with real credentials to git!
# =============================================================================

# =============================================================================
# PostgreSQL — Pronghorn Application Database
# =============================================================================
# System metadata server: users, projects, organizations, activity logs.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=pronghorn
POSTGRES_USER=pronghorn_admin
POSTGRES_PASSWORD=localdev123
POSTGRES_SSL=false

# =============================================================================
# PostgreSQL — Pronghorn Generated Applications Database
# =============================================================================
# Dedicated server for per-project databases (proj_*) created dynamically.
# Falls back to the Pronghorn Application values when not set.
POSTGRES_GENAPPS_HOST=localhost
POSTGRES_GENAPPS_PORT=5433
POSTGRES_GENAPPS_USER=pronghorn_genapps_admin
POSTGRES_GENAPPS_PASSWORD=localdev123
POSTGRES_GENAPPS_SSL=false

# =============================================================================
# Authentication — Microsoft Entra ID
# =============================================================================
# These must match your Entra ID App Registration.
#
# NOTE — Use ENTRA_* names, NOT AZURE_*. The @azure/identity SDK reserves
# AZURE_CLIENT_ID / AZURE_TENANT_ID for managed-identity / service-principal
# credential chains. If AZURE_CLIENT_ID is exported in the API process,
# DefaultAzureCredential treats it as a user-assigned MI clientId and fails
# with "No User Assigned or Delegated Managed Identity found for specified
# ClientId" whenever only a system-assigned MI is attached (Container Apps,
# AKS, App Service). The backend reads ENTRA_* with AZURE_* as a fallback,
# so existing local .env files still work, but prefer ENTRA_* in new setups.
ENTRA_TENANT_ID=                           # Entra ID Directory (tenant) ID
ENTRA_CLIENT_ID=                           # Entra ID Application (client) ID

# =============================================================================
# API
# =============================================================================
API_PORT=3001
PORT=3001
NODE_ENV=development
LOG_LEVEL=info
ALLOWED_ORIGINS=http://localhost:8081,http://localhost:8080
JWT_SECRET=local-dev-jwt-secret-change-me
SKIP_AUTH=true

# =============================================================================
# Frontend
# =============================================================================
FRONTEND_PORT=8081
