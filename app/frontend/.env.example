# =============================================================================
# Pronghorn Frontend — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env files with real credentials to git!
# =============================================================================

# =============================================================================
# Azure APIM Configuration (Primary API Gateway)
# =============================================================================
# The APIM gateway URL — all REST API calls go through this.
# For local dev with a local API server, use http://localhost:8080
VITE_API_BASE_URL=http://localhost:8080
# APIM subscription key (required when your gateway enforces subscription keys).
# Leave blank for local API development if no APIM key is required.
VITE_APIM_SUBSCRIPTION_KEY=

# =============================================================================
# WebSocket Configuration
# =============================================================================
# Explicit WebSocket URL for real-time features.
#
#   APIM Tier          | VITE_WS_URL value
#   ------------------- | -------------------------------------------
#   Consumption         | wss://<container-app>.azurecontainerapps.io/ws  (direct)
#   Basic / Standard+   | wss://<apim-name>.azure-api.net/ws             (via APIM)
#   Local development   | (leave blank — auto-derived from VITE_API_BASE_URL)
#
# If not set, the client derives ws(s):// from VITE_API_BASE_URL automatically.
# VITE_WS_URL=

# =============================================================================
# Microsoft Entra ID (MSAL) Authentication
# =============================================================================
# These must match your Entra ID App Registration.
# See README.md → "Microsoft Entra ID Setup" for instructions.
#
# NOTE: Variables are VITE_ENTRA_* (not VITE_AZURE_*) to stay consistent with
# the backend, which must use ENTRA_* to avoid the @azure/identity SDK
# reserving AZURE_CLIENT_ID/AZURE_TENANT_ID. The frontend MSAL config also
# accepts VITE_AZURE_* as a fallback for backward compatibility.
VITE_ENTRA_CLIENT_ID=                      # Entra ID Application (client) ID
VITE_ENTRA_TENANT_ID=                      # Entra ID Directory (tenant) ID (default: "organizations")
VITE_AZURE_REDIRECT_URI=http://localhost:8080  # OAuth redirect URI (must match App Registration)

# =============================================================================
# Authentication Mode
# =============================================================================
# Controls how authentication works in development:
#   "msal"    — Use Microsoft Entra ID (MSAL) authentication
#   "mock"    — Use mock authentication for local testing (no Azure needed)
#
# Production builds always use MSAL.
VITE_AUTH_MODE=mock

# =============================================================================
# Feature Flags
# =============================================================================

# =============================================================================
# GitHub OAuth
# =============================================================================
# Note: GitHub Client ID is only needed server-side (in app/backend/.env).
# No VITE_GITHUB_* variable is required for the frontend.
VITE_GITHUB_ORG=                          # Optional default GitHub organization in repository dialogs
# VITE_USE_AZURE_API=true
# VITE_ENABLE_DEBUG_MODE=false

# =============================================================================
# Collaboration
# =============================================================================
# Number of recent collaboration snapshots to pre-fetch on session load.
# Pre-fetched snapshots enable instant version-slider navigation with no loading states.
VITE_COLLABORATION_SNAPSHOT_PREFETCH_LIMIT=50  # [OPTIONAL] default: 50
