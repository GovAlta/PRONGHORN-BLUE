# =============================================================================
# Pronghorn API — Backend-Specific Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env files with real credentials to git!
#
# Shared variables (DB creds, auth IDs, ports, NODE_ENV, SKIP_AUTH) live in
# the root .env file (../../.env). The "npm run dev" script sources root .env
# first, then this file second — so values here override root defaults.
#
# Docker Compose: root .env → env_file → environment: overrides
# Production (Container Apps): no .env files; all vars injected by Terraform.
# =============================================================================

# =============================================================================
# Authentication — Microsoft Entra ID (JWT validation)
# =============================================================================
# Normally set in the root .env (../../.env), repeated here for visibility.
#
# NOTE — Use ENTRA_* names, NOT AZURE_*. The @azure/identity SDK (used by
# this API to call ARM, Azure OpenAI, etc.) reserves AZURE_CLIENT_ID and
# AZURE_TENANT_ID for its credential chain. If AZURE_CLIENT_ID is exported
# in the API process, ManagedIdentityCredential treats it as a user-assigned
# MI clientId and fails when only a system-assigned MI is attached — e.g.
# Container Apps deploys fail with "No User Assigned or Delegated Managed
# Identity found for specified ClientId". The middleware reads ENTRA_* with
# AZURE_* as a fallback for local-dev compatibility; production containers
# must use ENTRA_* only.
ENTRA_TENANT_ID=                           # [OPTIONAL] Entra ID Directory (tenant) ID (overrides root .env)
ENTRA_CLIENT_ID=                           # [OPTIONAL] Entra ID Application (client) ID (overrides root .env)

# =============================================================================
# Azure AI Foundry — via APIM Proxy
# =============================================================================
APIM_OPENAI_URL=                           # [OPTIONAL] APIM OpenAI proxy URL (e.g., https://apim-xxx.azure-api.net/openai)

# =============================================================================
# GitHub Integration
# =============================================================================
GITHUB_ORG=                                # [REQUIRED] GitHub organization that owns your *deployed app* repos

# GitHub App (required for all repository operations and workflow dispatch)
# Create a GitHub App, install it on your org, then supply the IDs and key below.
# The installation token is minted server-side from these values.
GITHUB_APP_ID=                             # [REQUIRED] GitHub App ID (e.g. "1234567")
GITHUB_APP_INSTALLATION_ID=                # [REQUIRED] Installation ID for the org install
GITHUB_APP_PRIVATE_KEY=                    # [REQUIRED] App private key (PEM contents)

# Genapp deploy workflow location — the repo + branch that hosts
# .github/workflows/genapp-deploy.yml. Independent of GITHUB_ORG (which is the
# user's deploy-target org). The ref must be a branch that ACTUALLY contains
# the workflow file — GitHub looks it up at the ref, not the default branch.
PRONGHORN_WORKFLOW_OWNER=pronghorn-blue-msft  # [OPTIONAL] Owner of the workflow repo (default: pronghorn-blue-msft)
PRONGHORN_WORKFLOW_REPO=pronghorn             # [OPTIONAL] Workflow repo name (default: pronghorn)
PRONGHORN_WORKFLOW_REF=main                   # [OPTIONAL] Branch to dispatch on (default: main)
DOCKER_DEPLOY_WORKFLOW_FILE=genapp-deploy.yml # [OPTIONAL] Workflow file dispatched for genapp Docker deploys (default: genapp-deploy.yml)

# =============================================================================
# Storage
# =============================================================================
STORAGE_BASE_PATH=./storage                # [OPTIONAL] Local Development file storage root (default: ./storage)
AZURE_STORAGE_ACCOUNT_NAME=               # [REQUIRED for blob-backed staging] Azure Storage account name; authenticate with az login locally
AZURE_STORAGE_TIMEOUT_MS=3000             # [OPTIONAL] Azure Storage operation timeout in milliseconds (default: 3000)

# =============================================================================
# WebSocket / Realtime
# =============================================================================
WS_URL=                                    # [OPTIONAL] Public WebSocket URL returned to clients

# =============================================================================
# External Services
# =============================================================================
API_BASE_URL=http://localhost:3001          # [OPTIONAL] Public base URL of this API
FRONTEND_URL=http://localhost:8080          # [OPTIONAL] Frontend URL for OAuth redirect callbacks

# =============================================================================
# OAuth Providers (Optional — for social login)
# =============================================================================
GOOGLE_CLIENT_ID=                          # [OPTIONAL] Google OAuth client ID
AZURE_OAUTH_CLIENT_ID=                     # [OPTIONAL] Azure AD OAuth client ID (can be same as AZURE_CLIENT_ID)
AZURE_OAUTH_TENANT=common                  # [OPTIONAL] Azure AD tenant for OAuth flow

# =============================================================================
# Deployment — Azure Container Apps
# =============================================================================
AZURE_SUBSCRIPTION_ID=                     # [OPTIONAL] Azure subscription ID for Container Apps deployment
AZURE_DEPLOY_RESOURCE_GROUP=Pronghorn-App  # [OPTIONAL] Azure resource group (default: Pronghorn-App)
AZURE_ACR_NAME=PronghornContainerRegistry  # [OPTIONAL] Azure Container Registry name
AZURE_ACR_LOGIN_SERVER=pronghorncontainerregistry.azurecr.io  # [OPTIONAL] ACR login server
AZURE_CONTAINER_APPS_ENV=                  # [OPTIONAL] Container Apps environment name
